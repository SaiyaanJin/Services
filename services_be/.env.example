# Backend Server Config
PORT=5050
HOST=0.0.0.0
DEBUG=False

# MongoDB Config
MONGO_URI=mongodb://localhost:27017/?replicaSet=rs0
MONGO_DB=Complaints
MONGO_COLLECTION=User_Input

# Mail Server Config
MAIL_SERVER=mail.grid-india.in
MAIL_USERNAME=domain\username
MAIL_PASSWORD=your_mail_password
MAIL_SMTP_ADDRESS=notifications@grid-india.in

# SSO Config
SSO_BASE_URL=https://sso.erldc.in:5000
SSO_API_KEY=your_sso_api_key
SSO_JWT_SECRET=sso_jwt_secret_here

# File Storage Configuration
UPLOAD_BASE_PATH=E:/Applications/Services/services_be/instance/htmlfi/
ZIP_TEMP_PATH=E:/Applications/Services/services_be/instance/ZipFiles/

# Security Configuration
ALLOWED_CORS_ORIGIN=http://localhost:3001
JWT_SECRET_KEY=generate_a_random_secret_here
